{
  "appId": "com.vestia.app",
  "appName": "Vestia",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "Geolocation": {
      "permissions": ["location"]
    },
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false
    }
  }
}
